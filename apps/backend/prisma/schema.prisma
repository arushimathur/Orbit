generator client {
  provider = "prisma-client-js"
}

// Plain Postgres for now -- Phase 1 only stores lat/lng as floats. PostGIS
// (for efficient geofence "point in radius" queries) comes back in Phase 2
// when Places/geofencing actually need it; that's a one-line schema addition.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CircleRole {
  owner
  member
}

enum LocationPrecision {
  exact
  city
}

model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  passwordHash   String
  avatarUrl      String?
  pushToken      String?
  // Sharing is paused (live position withheld from every circle) while this is in the
  // future; a far-future sentinel represents an indefinite pause ("Share my location" off).
  sharingPausedUntil   DateTime?
  // Edge-trigger guard for low-battery alerts: set when a "below threshold" notification
  // fires, cleared once battery recovers above the reset threshold, so repeated low pings
  // don't spam the circle every few seconds.
  lowBatteryNotifiedAt DateTime?
  createdAt      DateTime        @default(now())
  refreshTokens  RefreshToken[]
  circleMembers  CircleMember[]
  locationPings  LocationPing[]
  ownedCircles   Circle[]        @relation("CircleOwner")
  passwordResetTokens PasswordResetToken[]
  savedLocations SavedLocation[]
  placeEventsReceived PlaceEvent[] @relation("PlaceEventRecipient")
  placeEventsTriggered PlaceEvent[] @relation("PlaceEventActor")
  nicknamesGiven  Nickname[] @relation("NicknameOwner")
  nicknamesHeld   Nickname[] @relation("NicknameTarget")
  notificationPreference NotificationPreference?
  mutedMembers    MutedMember[] @relation("MutedMemberOwner")
  mutedByOthers   MutedMember[] @relation("MutedMemberTarget")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  codeHash  String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  @@index([userId])
}

model Circle {
  id         String         @id @default(uuid())
  name       String
  inviteCode String         @unique
  createdBy  String
  owner      User           @relation("CircleOwner", fields: [createdBy], references: [id])
  createdAt  DateTime       @default(now())
  members    CircleMember[]
}

model CircleMember {
  circleId String
  userId   String
  role     CircleRole @default(member)
  // Per (circle, member): lets someone share exact location with their household circle
  // but only city/area with an extended-family circle.
  locationPrecision LocationPrecision @default(exact)
  joinedAt DateTime   @default(now())

  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([circleId, userId])
  @@index([userId])
}

// Every ping is retained (not just the latest) so Phase 2/3 history & driving-report
// features can query past pings without a schema change.
model LocationPing {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lat        Float
  lng        Float
  accuracyM  Float?
  speedMps   Float?
  heading    Float?
  batteryPct Float?
  recordedAt DateTime
  createdAt  DateTime @default(now())

  @@index([userId, recordedAt(sort: Desc)])
}

// A user's saved place (e.g. "Home", "Work"). `isInside` tracks the last-observed
// geofence state so LocationsService can detect arrival/departure transitions on
// each new ping without needing PostGIS -- plain Haversine distance is enough at
// this scale. `isInside` is nullable (not defaulted to false) so the very first
// ping evaluated after a place is created only records a baseline instead of
// firing a spurious arrival/departure notification.
enum PlaceKind {
  home
  work
  custom
}

// "home"/"work" are per-person special places: every member can save their own, and the
// circle-wide places list (see PlacesService.listSharedForCircle) groups all members'
// home/work rows under one shared "Home"/"Work" label that resolves to each person's own
// address, rather than showing N separately-named identical places.
model SavedLocation {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  kind      PlaceKind @default(custom)
  lat       Float
  lng       Float
  radiusM   Float
  isInside  Boolean?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  placeEvents PlaceEvent[]

  @@index([userId])
}

enum PlaceEventType {
  arrived
  left
  low_battery
}

// Per-recipient notification row, fanned out to every circle member who shares
// a circle with the actor at the moment of the transition. actorName/placeName
// are denormalized at write time so notification history still renders correctly
// even after the actor's name changes, the actor's account is deleted, or the
// place itself is deleted.
model PlaceEvent {
  id              String         @id @default(uuid())
  recipientUserId String
  recipient       User           @relation("PlaceEventRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  actorUserId     String?
  actor           User?          @relation("PlaceEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorName       String
  placeId         String?
  place           SavedLocation? @relation(fields: [placeId], references: [id], onDelete: SetNull)
  placeName       String
  type            PlaceEventType
  occurredAt      DateTime
  createdAt       DateTime       @default(now())
  readAt          DateTime?

  @@index([recipientUserId, createdAt(sort: Desc)])
}

// Private to the viewer ("ownerId"): how *I* refer to a circle member, e.g. Rahul -> "Papa".
// Never visible to anyone else, including the person nicknamed.
model Nickname {
  id           String   @id @default(uuid())
  ownerId      String
  owner        User     @relation("NicknameOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  targetUserId String
  target       User     @relation("NicknameTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  nickname     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([ownerId, targetUserId])
}

// One row per user, upserted on first write. Global "tell me when..." toggles plus quiet
// hours; per-person muting lives in MutedMember below rather than as an array column so
// it stays queryable/indexable.
model NotificationPreference {
  userId            String   @id
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifyArrivals    Boolean  @default(true)
  notifyLowBattery  Boolean  @default(true)
  // Stored/exposed for UI parity with the design, not wired to any real lateness
  // detection yet (no such model exists) -- defaults off, same as the design mockup.
  notifyRunningLate Boolean  @default(false)
  // Plain "HH:mm", compared against server UTC time -- see NotificationsService.
  quietHoursStart   String?
  quietHoursEnd     String?
  updatedAt         DateTime @updatedAt
}

// Per-viewer mute of a specific circle member's arrival/departure/low-battery alerts.
model MutedMember {
  ownerId     String
  owner       User   @relation("MutedMemberOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  mutedUserId String
  mutedUser   User   @relation("MutedMemberTarget", fields: [mutedUserId], references: [id], onDelete: Cascade)

  @@id([ownerId, mutedUserId])
}
