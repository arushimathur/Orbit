# Copy to .env and fill in real values. Never commit the real .env file.

# Random long random strings — e.g. `openssl rand -hex 32`. Keep these secret and different from each other.
JWT_ACCESS_SECRET=changeme-access-secret
JWT_REFRESH_SECRET=changeme-refresh-secret

# Used by the backend when running outside Docker Compose (compose overrides this itself).
DATABASE_URL=postgresql://orbit:orbit@localhost:5432/orbit

# Maps use OpenFreeMap (openfreemap.org) by default -- free public vector tiles,
# no account or API key needed. No env var required unless you want to override
# the style (set NEXT_PUBLIC_MAP_STYLE_URL / EXPO_PUBLIC_MAP_STYLE_URL instead).

# SMTP credentials used to send "forgot password" reset-code emails.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=changeme
SMTP_PASS=changeme
SMTP_FROM="Orbit <no-reply@example.com>"
