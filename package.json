{
  "name": "orbit",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run build --workspace=@orbit/shared",
    "backend:dev": "npm run start:dev --workspace=@orbit/backend",
    "mobile:start": "npm run start --workspace=@orbit/mobile",
    "shared:build": "npm run build --workspace=@orbit/shared",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "expo": "~51.0.28",
    "react": "18.2.0",
    "react-native": "0.74.5"
  }
}
